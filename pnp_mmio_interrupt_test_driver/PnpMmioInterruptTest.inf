; PnpMmioInterruptTest.inf - optional installation file.
;
; Not required for userspace-ntos Driver Host testing.
; Included as a convenience for building/signing experiments.

[Version]
Signature="$WINDOWS NT$"
Class=System
ClassGuid={4d36e97d-e325-11ce-bfc1-08002be10318}
Provider=%ProviderName%
DriverVer=07/03/2026,0.1.0.0
CatalogFile=PnpMmioInterruptTest.cat

[DestinationDirs]
DefaultDestDir = 12

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
PnpMmioInterruptTest.sys = 1

[Manufacturer]
%ManufacturerName%=Standard,NTamd64

[Standard.NTamd64]
%DeviceName%=Install, Root\PnpMmioInterruptTest

[Install.NT]
CopyFiles=DriverCopyFiles

[DriverCopyFiles]
PnpMmioInterruptTest.sys

[Install.NT.Services]
AddService=PnpMmioInterruptTest,0x00000002,PnpMmioInterruptTest_Service

[PnpMmioInterruptTest_Service]
DisplayName=%ServiceName%
ServiceType=1
StartType=3
ErrorControl=1
ServiceBinary=%12%\PnpMmioInterruptTest.sys

[Strings]
ProviderName="PnpMmioInterruptTest"
ManufacturerName="PnpMmioInterruptTest"
DeviceName="PnpMmioInterruptTest PnP WDM MMIO/Interrupt Test Driver"
ServiceName="PnpMmioInterruptTest"
DiskName="PnpMmioInterruptTest Installation Disk"
