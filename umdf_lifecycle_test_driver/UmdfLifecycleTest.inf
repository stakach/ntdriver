; UmdfLifecycleTest.inf - UMDF v2 (UMDF 2.15) lifecycle test driver.
; User-mode driver DLL hosted by WUDFHost.exe through the WUDFRd.sys reflector.

[Version]
Signature   = "$WINDOWS NT$"
Class       = Sample
ClassGuid   = {78A1C341-4539-11d3-B88D-00C04FAD5171}
Provider    = %ManufacturerName%
DriverVer   = 07/06/2026,2.0.0.0
CatalogFile = UmdfLifecycleTest.cat
PnpLockdown = 1

[Manufacturer]
%ManufacturerName% = Standard,NTamd64

[Standard.NTamd64]
%DeviceName% = UmdfLifecycleTest_Install, ROOT\UMDF_LIFECYCLE_TEST

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
UmdfLifecycleTest.dll = 1

[DestinationDirs]
UMDriverCopy = 13 ; copy the driver DLL into the driver store package

; ================= Device install ==================================
[UmdfLifecycleTest_Install.NT]
CopyFiles = UMDriverCopy

[UMDriverCopy]
UmdfLifecycleTest.dll

[UmdfLifecycleTest_Install.NT.hw]
AddReg = UmdfLifecycleTest_Device_AddReg

[UmdfLifecycleTest_Device_AddReg]
HKR,,DeviceCharacteristics,0x10001,0x0100 ; FILE_DEVICE_SECURE_OPEN
HKR,,Security,,"D:P(A;;GA;;;BA)(A;;GA;;;SY)(A;;GA;;;BU)"

; ================= Reflector service ===============================
[UmdfLifecycleTest_Install.NT.Services]
AddService = WUDFRd,0x000001fa,WUDFRD_ServiceInstall

[WUDFRD_ServiceInstall]
DisplayName    = %WUDFRD.DisplayName%
ServiceType    = 1
StartType      = 3
ErrorControl   = 1
ServiceBinary  = %12%\WUDFRd.sys
LoadOrderGroup = Base

; ================= UMDF binding ====================================
[UmdfLifecycleTest_Install.NT.Wdf]
UmdfService = UmdfLifecycleTest, UmdfLifecycleTest_Install
UmdfServiceOrder = UmdfLifecycleTest
UmdfKernelModeClientPolicy = AllowKernelModeClients
UmdfImpersonationLevel = Impersonation

[UmdfLifecycleTest_Install]
UmdfLibraryVersion = 2.15.0
ServiceBinary = %13%\UmdfLifecycleTest.dll

[Strings]
ManufacturerName   = "userspace-ntos"
DeviceName         = "UMDF Lifecycle Test Device"
DiskName           = "UMDF Lifecycle Test Install Disk"
WUDFRD.DisplayName = "Windows Driver Foundation - User-mode Driver Framework Reflector"
