; PowerPnpMmioTest.inf - optional installation file.
;
; Not required for userspace-ntos Driver Host testing.
; Included as a convenience for building/signing experiments.

[Version]
Signature="$WINDOWS NT$"
Class=System
ClassGuid={4d36e97d-e325-11ce-bfc1-08002be10318}
Provider=%ProviderName%
DriverVer=07/04/2026,0.1.0.0
CatalogFile=PowerPnpMmioTest.cat

[DestinationDirs]
DefaultDestDir = 12

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
PowerPnpMmioTest.sys = 1

[Manufacturer]
%ManufacturerName%=Standard,NTamd64

[Standard.NTamd64]
%DeviceName%=Install, Root\PowerPnpMmioTest

[Install.NT]
CopyFiles=DriverCopyFiles

[DriverCopyFiles]
PowerPnpMmioTest.sys

[Install.NT.Services]
AddService=PowerPnpMmioTest,0x00000002,PowerPnpMmioTest_Service

[PowerPnpMmioTest_Service]
DisplayName=%ServiceName%
ServiceType=1
StartType=3
ErrorControl=1
ServiceBinary=%12%\PowerPnpMmioTest.sys

[Strings]
ProviderName="PowerPnpMmioTest"
ManufacturerName="PowerPnpMmioTest"
DeviceName="PowerPnpMmioTest PnP Power WDM MMIO/Interrupt Test Driver"
ServiceName="PowerPnpMmioTest"
DiskName="PowerPnpMmioTest Installation Disk"
